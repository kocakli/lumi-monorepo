    "pair.subtitle" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Verbinde dich mit einer anderen Seele, indem du ihren privaten Code eingibst. Sobald die Verbindung steht, wird eure Anwesenheit sanft geteilt, ohne eure Identität zu offenbaren."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Connect with another soul by entering their private code. Once paired, your presence will be softly shared without revealing your identity."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Conéctate con otra alma introduciendo su código privado. Una vez vinculados, vuestra presencia se compartirá con suavidad sin revelar vuestra identidad."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Reliez-vous à une autre âme en saisissant son code privé. Une fois liés, votre présence sera doucement partagée sans révéler votre identité."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Connettiti con un'altra anima inserendo il suo codice privato. Una volta legati, la vostra presenza sarà condivisa con dolcezza, senza rivelare la vostra identità."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "もうひとりのプライベートコードを入力すれば、ふたりだけでそっと言葉を交わせます。お互いの身元を明かすことはありません。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "다른 사람의 비밀 코드를 입력하면 둘만의 작은 정원이 열려요. 신원이 드러나지 않은 채 조용히 곁에 있을 수 있어요."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Conecte-se a outra alma digitando o código privado dela. Uma vez pareados, sua presença será compartilhada com carinho sem revelar quem você é."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Başka bir gönülle, onun özel kodunu girerek bağlan. Bir kere eşleştiğinizde, varlığınız kim olduğunuzu söylemeden incelikle paylaşılacak."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "输入对方的私密码,你们之间就有了一条只属于两个人的信道。彼此的身份始终是匿名的。"
          }
        }
      }
    },
