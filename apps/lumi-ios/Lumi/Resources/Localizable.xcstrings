    "sensitive.description" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Passe an, welche Worte dich an empfindsamen Tagen erreichen. Wir senden dir sanftere, behutsamere Botschaften."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Adjust the kind of messages you receive during sensitive times. We'll send gentler, more nurturing words."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ajusta el tono de los mensajes que recibes en los días más sensibles. Te enviaremos palabras más suaves y acogedoras."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ajuste la nature des mots qui te parviennent durant les jours plus délicats. Nous t'enverrons des paroles plus douces et plus apaisantes."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Adatta il tono dei messaggi che ricevi nei giorni più delicati. Ti invieremo parole più dolci e avvolgenti."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ゆらぎやすい日々に届く言葉を、すこし変えます。よりやさしく、寄り添うひとことをお届けします。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "예민한 시기에 받는 말의 결을 살짝 바꿔요. 더 부드럽고 다정한 말을 전해 드릴게요."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ajuste o tom das palavras que chegam nos dias mais sensíveis. Vamos enviar palavras ainda mais suaves e acolhedoras."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hassas zamanlarda sana ulaşan sözlerin tonunu ayarla. Sana daha yumuşak, daha sarmalayıcı kelimeler göndereceğiz."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在敏感的日子里,调整你收到话语的口吻。我们会送来更温柔、更贴心的字句。"
          }
        }
      }
    },
