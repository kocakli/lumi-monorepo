    "notif_permission.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bleib mit deinem\ninneren Licht verbunden"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Stay connected to\nyour inner light"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mantente conectado\na tu luz interior"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Restez relié à\nvotre lumière intérieure"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Resta connesso\nalla tua luce interiore"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "あなたの心の灯りに\nそっと寄り添えるように"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "당신 마음의 등불에\n조용히 곁에 있을게요"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mantenha a conexão\ncom sua luz interior"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "İçindeki ışıkla\nbağlı kal"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "让 Lumi\n陪你守住内心的光"
          }
        }
      }
    },
