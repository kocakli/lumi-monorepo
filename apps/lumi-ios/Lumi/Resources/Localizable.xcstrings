    "receive.onboarding.description" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wische über die Botschaften und teile deine Energie.\nDeine Reaktionen formen den\nZufluchtsort für alle."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Swipe messages to share your energy.\nYour feedback shapes the\nsanctuary for everyone."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Desliza los mensajes para compartir tu energía.\nTus reacciones moldean el\nsantuario para todos."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Glissez sur les messages pour partager votre énergie.\nVos retours façonnent le\nsanctuaire pour tous."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Scorri i messaggi per condividere la tua energia.\nLe tue reazioni plasmano il\nsantuario per tutti."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "言葉をスワイプして、あなたの気持ちを伝えてください。\nあなたの一票が、この庭を\nもっとやさしくしていきます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "한 줄을 쓸어 넘겨 당신의 마음을 전해 보세요.\n당신의 한 표가 이 정원을\n모두에게 더 다정한 곳으로 만듭니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Deslize as cartas para compartilhar sua energia.\nSeu carinho molda este\nrefúgio para todo mundo."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sözleri sürükleyerek hissini paylaş.\nSenin verdiğin oy, bu sığınağı\nherkes için daha güzel kılar."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "滑动话语,把你的感受告诉我们。\n你的每一次反馈,都让这个\n小院变得更温柔。"
          }
        }
      }
    },
