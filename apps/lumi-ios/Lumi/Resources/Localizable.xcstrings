    "notif_permission.allow" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "SANFTE ERINNERUNGEN ERLAUBEN"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ALLOW GENTLE NUDGES"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "PERMITIR RECORDATORIOS SUAVES"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "AUTORISER LES RAPPELS DOUX"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "CONSENTI PROMEMORIA DOLCI"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "やさしい通知を許可"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "다정한 알림 허용"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "PERMITIR LEMBRETES SUAVES"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "NAZİK HATIRLATMALARA İZİN VER"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "允许温柔提醒"
          }
        }
      }
    },
    "notif_permission.description" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lumi kann dich sanft daran erinnern, innezuhalten, zu atmen und ein freundliches Wort zu empfangen, wenn du es am meisten brauchst."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lumi can gently remind you to pause, breathe, and receive a kind word when you need it most."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lumi puede recordarte con suavidad que pares, respires y recibas una palabra amable cuando más lo necesites."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lumi peut vous rappeler doucement de faire une pause, de respirer et de recevoir un mot bienveillant quand vous en avez le plus besoin."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lumi può ricordarti con dolcezza di fermarti, respirare e ricevere una parola gentile quando ne hai più bisogno."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "本当に必要なときだけ、Lumiがそっとひとことをお届けします。深呼吸して、やさしい言葉を受け取ってください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "정말로 필요한 순간에만 Lumi가 한 줄의 따뜻한 말을 보냅니다. 깊게 숨을 쉬고 다정한 말을 받아 보세요."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lumi pode te lembrar com carinho de pausar, respirar e receber uma palavra gentil quando você mais precisa."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lumi sana, ihtiyacın olan anda durmanı, derin bir nefes almanı ve nazik bir söz almanı incelikle hatırlatabilir."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lumi 会在你最需要的时刻,轻轻提醒你停下脚步、深呼吸,接住一句温柔话。"
          }
        }
      }
    },
